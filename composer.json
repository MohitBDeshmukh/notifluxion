{
    "name": "mohitbdeshmukh/notifluxion",
    "description": "A scalable, versioned, future-proof, and provider-agnostic Laravel Notification Library",
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/MohitBDeshmukh/notifluxion",
    "authors": [
        {
            "name": "Mohit Deshmukh",
            "role": "Lead Architect"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/notifications": "^10.0|^11.0",
        "illuminate/database": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Notifluxion\\LaravelNotify\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Notifluxion\\LaravelNotify\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Notifluxion\\LaravelNotify\\Providers\\NotificationServiceProvider"
            ],
            "aliases": {
                "Notify": "Notifluxion\\LaravelNotify\\Facades\\Notify"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
